{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|apply_patch|functions.apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "touch \"$(git rev-parse --show-toplevel)/.agents/session-changed\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/scripts/on-session-stop.sh\""
          }
        ]
      }
    ]
  }
}
